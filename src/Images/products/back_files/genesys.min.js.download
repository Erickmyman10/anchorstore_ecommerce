  });
  Auth.registerCommand('refreshToken', e => {
    // If refreshToken is available, get the new jwt token using that. Else, get jwt directly using 'getTokens'.
    if (!bCleared) {
      // Block refresh token for implicit flow
      const authGrantType = $$('authGrantType');
      if (authGrantType === 'implicit') {
        const errorData = {
          error: 'unsupported_grant_type',
          error_description: 'Refresh token is not available for implicit flow. Please use authorization code flow to enable token refresh.',
          authGrantType
        };
        Auth.publish('error', errorData);
        e.reject(errorData);
        return;
      }
      if ($$('refreshToken')) {
        lib_axios({
          url: `${sApiEndpoint}/api/v2/webdeployments/token/refresh`,
          method: 'post',
          responseType: 'json',
          data: {
            refreshToken: $$('refreshToken')
          }
        }).then(response => {
          const {
            jwt
          } = response && response.data || {};
          if (jwt) {
            $$('authenticated', true); // set 'authenticated' state in the data model

            setJwt(jwt);
            Auth.publish('authenticated', {
              jwt,
              authGrantType
            });
            e.resolve(response.data);
          } else {
            $$('authenticated', false); // set 'authenticated' state in the data model

            Auth.publish('tokenError', response); // publish "tokenError" event when no jwt is provided

            e.reject('Invalid or no token received');
          }
        }).catch(error => {
          // eslint-disable-line
          const {
            data
          } = error.response || {};
          $$('authenticated', false);
          Auth.publish('error', data || {}); // publish "error" event when the request fails

          const {
            status
          } = error && error.response || {};
          if (bLoggingOut) {
            bLoggingOut = false; // reset
            e.reject('Unable to fetch authentication token for logout'); // don't re-authenticate when logout is in-progress and refresh request failed. Consider it logged out.
          } else if (status) {
            switch (status) {
              case 400:
              case 401:
              case 403:
                // retry the same refresh call once
                retryAxiosOnce(error, e, response => {
                  const {
                    jwt
                  } = response && response.data || {};
                  if (jwt) {
                    $('authenticated', true);
                    setJwt(jwt);
                    Auth.publish('authenticated', {
                      jwt,
                      authGrantType
