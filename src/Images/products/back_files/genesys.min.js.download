      // If the deployment is active, initialize supported products
      if (status && status === STATUS_ACTIVE) {
        initializeCoreProducts(config); // always initialize core products like Journey irrespective of Auth enabled

        if (bAuthEnabled && bAuthEnabled === true) {
          // check if Authentication is needed and fetch jwt
          let sStoredAuthTkn = GenesysJS.data('Auth.jwt');
          if (sStoredAuthTkn) {
            // check if Auth token is already available and initialize the products, else no
            initializeProducts(config);
          } else {
            if (allowSessionUpgrade) {
              GenesysJS.subscribe('LocalStorage.ready', () => {
                // stepUp conversation: when authCode is available, fetch jwt
                // When allow session upgrade is enabled, subscribe to LocalStorage ready event before initializing products. 
                // This is to fix where we aren't getting LogoutEvent in WS from Shyrka.
                setTimeout(() => {
                  GenesysJS.command(`${sStoragePlugin}.get`, {
                    name: `${deploymentId}:authenticating`
                  }).then(authenticating => {
                    if (authenticating === 'true') {
                      getAuthTokenAndInitProducts(config);
                    } else {
                      GenesysJS.command(`${sStoragePlugin}.get`, {
                        name: `${deploymentId}:signingIn`
                      }).then(signingIn => {
                        if (signingIn === 'true') {
                          getAuthTokenAndInitProducts(config);
                        } else {
                          initializeProducts(config);
                          GenesysJS.log('Conversation Session can later be stepped up to authenticated session.');
                        }
                      });
                    }
                  });
                }, 200);
              });
            } else {
              GenesysJS.subscribe('Auth.ready', () => {
                // wait for the brand AuthProvider plugin
                // WEBMESS-1632: For normal Authenticated Messenger, subscribe to LocalStorage ready event before initializing.
                // This ensures we can check if auth tokens stored in the local storage are available.
                GenesysJS.subscribe('LocalStorage.ready', () => {
                  setTimeout(() => {
                    if (!bProductsInitialized) getAuthTokenAndInitProducts(config);
                  }, 200); // Adding this as the existing cdls library takes this time to initialize properly along with data availability.
                });
              });
            }
          }

          // This event is published after LocalStorage plugin is ready and Auth plugin authenticated. Subscribing to it to get the jwt from storage and restore Messenger.
          GenesysJS.subscribe('Auth.authenticated', () => {
            if (!bProductsInitialized) {
              sStoredAuthTkn = GenesysJS.data('Auth.jwt');
              if (sStoredAuthTkn) {
                initializeProducts(config);
              }
            }
          });
        } else {
          // normal ephimeral conversation
          initializeProducts(config);
        }
      }

      // Execute items inside the queue after CXBus, core plugins, and the configuration are loaded.
      GenesysJS.ready();
      Genesys('executeQueue');
    }, () => {
      // executeQueue() tells CXBus to execute any customer activity that was queued.
      // This must always execute or else their code will never run. Even if fetching
      // the configuration fails, we should let their code run.
      GenesysJS.ready();
      Genesys('executeQueue');
    });
  } else {
    const previewConfig = {
      deploymentConfig: {
        messenger: {
          enabled: true,
          preview: true
        }
      }
    };

    // Init Messenger with preview config
    init_messenger(previewConfig, GenesysJS);

    // Init the thirdparty iframe in preview mode
    // downstream plugins will follow preview flag
    init_thirdparty(previewConfig, GenesysJS);
    GenesysJS.ready();
    Genesys('executeQueue');
  }
});

