          target[prop] = obj[prop];
        }
      }
    }
  };

  //Loop through each object and conduct a merge
  for (; i < args.length; i++) {
    merger(args[i]);
  }
  return target;
}

/**
 * A function that accepts object, filters and returns only properties removing any methods that it may contain.
 * @param {object} obj
 */
function cloneObjectPropsOnly(obj) {
  const newObj = {};
  for (const key in obj) {
    if (Object.prototype.hasOwnProperty.call(obj, key) && typeof obj[key] !== 'function') {
      newObj[key] = obj[key];
    }
  }
  return newObj;
}

/**
 * function that checks if it is firefox browser and return boolean
 */
function isFireFox() {
  const uA = navigator.userAgent.match(/Firefox[/\s](\d+\.\d+)/);
  return Array.isArray(uA) && uA.length >= 2;
}

/**
 * WEBMESS-289, WEBMESS-1579: [accessibility] - to check whether it is an iphone device and apply the aria properties only on them
 * to avoid background page navigation while using with screen readers
 **/
function isIphone() {
  const bIphone = /iP(hone|od)/i.test(window.navigator.userAgent);
  if (bIphone) return true;else return false;
}

