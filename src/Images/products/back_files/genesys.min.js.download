  MessengerHelper.registerCommand('getWebSocketData', e => {
    if (ws) {
      e.resolve({
        isClosed: ws.isClosed,
        isOpened: ws.isOpened,
        isClosing: ws.isClosing
      });
    } else {
      e.reject('No WebSocket connection available.');
    }
  });
  MessengerHelper.registerCommand('makeRequest', e => {
    if (bMessengerCleared) {
      e.reject(CLEARED_REJECTION_MESSAGE);
    } else {
      const {
        url,
        method,
        responseType,
        headers,
        ...others
      } = e.data || {};
      function fMakeRequest() {
        MessengerHelper.command('GenesysVendors.Axios', {
          url
        }).then(axios => {
          axios({
            url,
            method,
            responseType: responseType || 'json',
            headers,
            ...others
          }).then(response => {
            e.resolve({
              data: response.data,
              headers: response.headers,
              status: response.status,
              statusText: response.statusText
            });
          }, error => {
            const oError = error && error.response ? error.response : error;
            e.reject(JSON.parse(JSON.stringify(oError || {})));
          }).catch(error => {
            e.reject(JSON.parse(JSON.stringify(error || {})));
          });
        }).catch(({
          error
        }) => {
          e.reject(JSON.parse(JSON.stringify(error || {})));
        });
      }
      if (e && util/* ALLOWED_PLUGINS */.kp.includes(e.commander)) {
        /**
         * Check if Vendors plugin is loaded, if not load it and then make the request
         */

        if (bVendorsPlugin) {
          fMakeRequest();
        } else {
          Genesys('loadPlugin', 'GenesysVendors', {}, false, () => {
            bVendorsPlugin = true;
            fMakeRequest();
          });
        }
      } else {
        e.reject('Unauthorized Access! Only MessagingService plugin is allowed to access this command.');
      }
    }
  });
  MessengerHelper.registerCommand('uploadRequest', e => {
    if (bMessengerCleared) {
      e.reject(CLEARED_REJECTION_MESSAGE);
    } else {
      const {
        url,
        headers,
        data
      } = e.data || {};
      function fUploadRequest() {
        MessengerHelper.command('GenesysVendors.Axios', {
          url
        }).then(axios => {
          const CancelToken = axios.CancelToken;
          fileUploadSource = CancelToken.source();
          axios.put(url, data, {
            headers,
            onUploadProgress: progressEvent => {
              const {
                loaded,
                total
              } = progressEvent;
              const percentage = Math.floor(loaded * 100 / total);
              MessengerHelper.publish('uploadProgress', {
                percentage,
                loaded,
                total
              });
            },
            cancelToken: fileUploadSource.token
          }).then(response => {
            e.resolve({
              data: response.data,
              headers: response.headers,
              status: response.status,
              statusText: response.statusText
            });
          }, error => {
            e.reject(JSON.parse(JSON.stringify(error || {})));
          }).catch(error => {
            e.reject(JSON.parse(JSON.stringify(error || {})));
          });
        });
      }
      if (e && util/* ALLOWED_PLUGINS */.kp.includes(e.commander)) {
        /**
         * Check if Vendors plugin is loaded, if not load it and then make the request
         */

        if (bVendorsPlugin) {
          fUploadRequest();
        } else {
          Genesys('loadPlugin', 'GenesysVendors', {}, false, () => {
            bVendorsPlugin = true;
            fUploadRequest();
          });
        }
      } else {
        e.reject('Unauthorized Access! Only MessagingService plugin is allowed to access this command.');
      }
    }
  });
  MessengerHelper.registerCommand('cancelRequest', e => {
    if (bMessengerCleared) {
      e.reject(CLEARED_REJECTION_MESSAGE);
    } else if (e && util/* ALLOWED_PLUGINS */.kp.includes(e.commander)) {
      if (fileUploadSource) {
        fileUploadSource.cancel();
        fileUploadSource = ''; // reset
        e.resolve();
      }
    } else {
      e.reject('Unauthorized Access! Only MessagingService plugin is allowed to access this command.');
    }
  });
  MessengerHelper.registerCommand('getCustomLabels', e => {
    if (bMessengerCleared) {
      e.reject(CLEARED_REJECTION_MESSAGE);
    } else {
      let customLangLabels = {};
      const {
        language
      } = e.data;
      const snippetConfig = MessengerHelper.data('GenesysJS.snippetConfig') || {};
      const {
        deploymentId
      } = snippetConfig;

      // download the custom language file only when the deploymentID and language is available
      if (deploymentId && language) {
        // download the custom language file from cdn url
        Genesys('loadJSON', `${customLabelUrl}/${deploymentId}/${language}.json`, oCustomLangStrings => {
          try {
            if (oCustomLangStrings) {
              const customLangStrings = JSON.parse(oCustomLangStrings);
              if (customLangStrings.messenger) {
                customLangLabels = customLangStrings.messenger;
                e.resolve({
                  customLangLabels: customLangLabels
                });
              }
            }
          } catch (err) {
            e.reject(err);
          }
        }, err => {
          // Reject and throw an error in the console
          e.reject(err);
        });
      } else {
        // Reject and throw an error in the console
        e.reject('Deployment Id or language is not available');
      }
    }
  });

  //WEBMESS-2146: getDeviceInfo command
  /**
   * Returns device information for plugins to enable device-specific functionality
   */
  MessengerHelper.registerCommand('getDeviceInfo', e => {
    //cSpell: ignore macintel, macppc, iemobile, cros, crios, fxios
    if (bMessengerCleared) {
      e.reject(CLEARED_REJECTION_MESSAGE);
    } else if (e && util/* ALLOWED_PLUGINS */.kp.includes(e.commander)) {
      try {
        var _window$screen, _window$screen2;
        const sUa = navigator.userAgent || '';
        const sPlatform = navigator.platform || '';
        const nTouchPoints = navigator.maxTouchPoints || 0;

