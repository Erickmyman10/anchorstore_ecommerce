 * function that filters iframe allow attribute values to only include permitted ones.
 * @param {string} allowString - The allow attribute string (e.g. "camera; microphone; geolocation")
 * @returns Filtered string with only permitted values (e.g. "camera; microphone") or empty string if none found
 */
function filterIframeAllowAttribute(allowString) {
  return allowString.split(';').map(feature => feature.trim()).filter(feature => IFRAME_PERMITTED_ALLOW_ATTR_VALUES.includes(feature)).join('; ');
}

/**
 * function that can shallow or deep merge given 2 objects
 * @param  {boolean} true - deep merge, false - shallow merge
 * @param  {obj1, ob2, ...} objects to merge
 */
function merge(...args) {
  // Variables
  const target = {};
  let deep = false;
  let i = 0;

  // Check if a deep merge
  if (typeof args[0] === 'boolean') {
    deep = args[0];
    i++;
  }

  // Merge the object into the target object
  const merger = obj => {
    for (const prop in obj) {
      if (Object.prototype.hasOwnProperty.call(obj, prop)) {
        if (deep && Object.prototype.toString.call(obj[`${prop}`]) === '[object Object]') {
          // If we're doing a deep merge and the property is an object
          if (Object.prototype.toString.call(target[`${prop}`]) === '[object Object]') {
