  // Append a html app in its own iframe
  MessengerHelper.registerCommand('injectFrame', e => {
    if (bMessengerCleared) {
      e.reject(CLEARED_REJECTION_MESSAGE);
    } else if (e && util/* ALLOWED_PLUGINS */.kp.includes(e.commander)) {
      const {
        htmlUrl,
        styles,
        title,
        name,
        id,
        allow
      } = e.data || {};
      const oURL = new URL(htmlUrl);
      if (verifyOrigin(oURL.origin)) {
        // validate the URL is a URL and from a whitelisted origin (see utils.js)
        // Create iframe node
        const iframe = document.createElement('iframe');

        // Populate iframe properties
        iframe.src = oURL.origin + oURL.pathname + oURL.search; // Rebuild URL from URL properties
        iframe.title = checkForJavascript(title || '');
        iframe.name = checkForJavascript(name || '');
        iframe.id = checkForJavascript(id);
        iframe.allowFullscreen = true;
        if (allow) {
          iframe.allow = (0,util/* filterIframeAllowAttribute */.aU)(allow);
        }

        // Append iframe styles
        iframe.classList.add('genesys-mxg-frame'); // default existing common class

        if (styles && Object.keys(styles)) {
          Object.keys(styles).forEach(propertyName => {
            iframe.style[propertyName] = styles[propertyName];
          });
        }

        // Convert iframe node to an HTML string and sanitize the HTML string
        const sCleanHTML = purify.sanitize(iframe.outerHTML, {
          ALLOWED_TAGS: ['iframe'],
          ADD_ATTR: ['src', 'allowfullscreen', 'title', 'class', 'name', 'id', 'allow']
        });

        // Append the sanitized HTML into the Messenger container
        document.getElementById('genesys-messenger').insertAdjacentHTML('beforeend', sCleanHTML);
        e.resolve();
      } else {
        e.reject();
      }
    } else {
      e.reject();
    }
  });

  // To set bottom position of Launcher/Messenger based on the position config
  MessengerHelper.registerCommand('setPositions', e => {
    if (bMessengerCleared) {
      e.reject(CLEARED_REJECTION_MESSAGE);
    } else {
      const {
        showLauncher
      } = e.data || {};
      const deploymentConfig = MessengerHelper.data('GenesysJS.deploymentConfig') || {};
      const {
        position,
        messenger: oMessengerConfig
      } = deploymentConfig || {};
      const {
        launcherButton
      } = oMessengerConfig || {};
      const {
        visibility
      } = launcherButton || {};
      const ndMessengerFrame = document.getElementById('genesys-mxg-container-frame');

      //set the messenger config position
      if (position) {
        setPositionValues(position);
      }
      if (visibility && visibility.toLowerCase() === 'ondemand') {
        if (showLauncher) {
          ndMessengerFrame.style.bottom = `${iMessengerLauncherSpace}px`;
        } else {
          ndMessengerFrame.style.bottom = `${oPosition.bottomSpace}px`;
        }
      }
    }
  });

  /**
   * To get frames dimensions while zooming -  WEBMESS-1399
   * @return {
   *  messengerFrame: {
   *    bottom,
   *    top,
   *    height,
   *    width
   *  },
   * launcherFrame: {
   *    bottom,
   *    top,
   *    height,
   *    width
   *  }
   * }
   */
  MessengerHelper.registerCommand('getDimension', e => {
    const ndLauncherIframe = document.getElementById('genesys-mxg-frame');
    const ndMessengerFrame = document.getElementById('genesys-mxg-container-frame');
    const styles = {
      messengerFrame: {},
      launcherFrame: {}
    };
    if (ndMessengerFrame && ndMessengerFrame.style) {
      styles.messengerFrame = getDimension(ndMessengerFrame);
    }
    if (ndLauncherIframe && ndLauncherIframe.style) {
      styles.launcherFrame = getDimension(ndLauncherIframe);
    }
    e.resolve(styles);
  });

  /**
   * sets frame width and height
   * MessengerFrame - Engage, Conversation/Home app
   * LauncherFrame - Launcher button
   * CobrowseFrame - TODO
   */
  MessengerHelper.registerCommand('setDimension', e => {
    if (bMessengerCleared) {
      e.reject(CLEARED_REJECTION_MESSAGE);
    } else {
      const ndIframe = document.getElementById('genesys-mxg-frame');
      const ndMessengerFrame = document.getElementById('genesys-mxg-container-frame');
      const {
        engage,
        launcher,
        conversations,
        toaster
      } = e.data;
      let bDimChanged = false;

      // Launcher button dimensions
      if (launcher) {
        const {
          width,
          height,
          addClass,
          removeClass
        } = launcher || {};
        if (typeof height === 'number' && height != oLauncher.height) bDimChanged = true;
        oLauncher.height = height;
        oLauncher.width = width;

        /**WEBMESS-787 If the laucher object has addClass/removeClass params, add or remove the classes from iFrame like Conversations object */

        if (ndIframe && addClass) addClass.map(value => value && ndIframe.classList.add(value));
        if (ndIframe && removeClass) removeClass.map(value => value && ndIframe.classList.remove(value));
        setIframeDimension(ndIframe, width, height);
      }

      // Engage app dimensions
      if (engage) {
        const {
          width,
          height
        } = engage;
        let iTotalHeight = height;
        let iTotalWidth = width;
        if (typeof height === 'number' && height != oEngage.height) bDimChanged = true;

        // store locally what ever dimensions you get.
        oEngage.height = height;
        oEngage.width = width;

        // when both Toaster and Enage are present, combine their height
        if (oToast.height && height) {
          iTotalHeight = oToast.height + height;
        }
        if (oToast.width && width) {
          iTotalWidth = oToast.width;
        }
        setIframeDimension(ndMessengerFrame, iTotalWidth, iTotalHeight);
      }

      // Conversation app dimensions
      if (conversations) {
        const {
          iHeight,
          iWidth
        } = getAppDimensions(conversations, ndMessengerFrame);
        if (typeof iHeight === 'number' && iHeight != oMess.height) bDimChanged = true;
        oMess.height = iHeight;
        oMess.width = iWidth;
        setIframeDimension(ndMessengerFrame, iWidth, iHeight);
      } else {
        // oMess.height = 0;
        // oMess.width = 0;
      }
      if (toaster) {
        let {
          width: toasterWidth,
          height: toasterHeight
        } = toaster;
        const {
          addClass,
          removeClass
        } = toaster;

        // store locally what ever dimensions you get.
        oToast.height = toasterHeight;
        oToast.width = toasterWidth;
        if (typeof toasterHeight === 'number' && toasterHeight != oMess.height) bDimChanged = true;

        // Because toaster appears inside Messenger container, apply actual Messenger dimensions.
        if (oMess.height) toasterHeight = oMess.height;
        if (oMess.width) toasterWidth = oMess.width;
        setIframeDimension(ndMessengerFrame, toasterWidth, toasterHeight);
        if (ndIframe && addClass) addClass.map(value => value && ndIframe.classList.add(value));
        if (ndIframe && removeClass) removeClass.map(value => value && ndIframe.classList.remove(value));
      }
      if (bDimChanged) {
        MessengerHelper.publish('dimensions', {
          messenger: {
            height: oMess.height,
            width: oMess.width
          },
          launcher: {
            height: oLauncher.height,
            width: oLauncher.width
          },
          toaster: {
            height: oToast.height,
            width: oToast.width
          },
          engage: {
            height: oEngage.height,
            width: oEngage.width
          }
        });
      }

      // WEBMESS-289: adding and removing aria properties to the iframe parent div to avoid background page navigation in iphones while using with voiceover
      setAriaAttributes();

      //  set width and height of iFrame
      if (ndIframe || ndMessengerFrame) {
        e.resolve();
      } else {
        e.reject('No styles or className provided for Messenger iFrame');
      }
    }
  });
  MessengerHelper.registerCommand('setDirection', e => {
    const ndIframe = document.getElementById('genesys-mxg-frame');
    const ndMessengerFrame = document.getElementById('genesys-mxg-container-frame');
    const {
      direction,
      position
    } = e.data || {};
    if (position) {
      //update position based on new config changes
      setPositionValues(position);
    }
    const {
      alignment
    } = oPosition;
    function setToLeft() {
      //update styles to force Iframe left
      // For Launcher iframe
      ndIframe.style.right = 'unset';
      ndIframe.style.left = `${oPosition.sideSpace}px`;
      ndIframe.style.bottom = `${oPosition.bottomSpace}px`;

      // For Messenger iframe
      ndMessengerFrame.style.right = 'unset';
      ndMessengerFrame.style.left = `${oPosition.sideSpace}px`;
      ndMessengerFrame.style.bottom = `${ndIframe.clientHeight ? ndIframe.clientHeight + iMessengerBottomPadding + oPosition.bottomSpace : oPosition.bottomSpace}px`;
    }
    function setToRight() {
      //update styles to force Iframe right
      // For Launcher iframe
      ndIframe.style.left = 'unset';
      ndIframe.style.right = `${oPosition.sideSpace}px`;
      ndIframe.style.bottom = `${oPosition.bottomSpace}px`;

      // For Messenger iframe
      ndMessengerFrame.style.left = 'unset';
      ndMessengerFrame.style.right = `${oPosition.sideSpace}px`;
      ndMessengerFrame.style.bottom = `${ndIframe.clientHeight ? ndIframe.clientHeight + iMessengerBottomPadding + oPosition.bottomSpace : oPosition.bottomSpace}px`;
    }
    function setDirection(sDirection) {
      switch (sDirection) {
        case 'rtl':
          setToLeft();
          break;
        case 'ltr':
          setToRight();
          break;
        default:
          break;
      }
    }

    /*
      * Set iframe position based on the config alignment value
      * right, left or auto: detect position based on document.dir
    */
    if (ndIframe && (position || sDocumentDirection)) {
      if (alignment === 'auto') {
        if (sDocumentDirection) {
          setDirection(sDocumentDirection);
          e.resolve();
        } else {
          setDirection(direction);
          e.resolve();
        }
      } else if (alignment === 'left') {
        setToLeft();
        e.resolve();
      } else if (alignment === 'right') {
        setToRight();
        e.resolve();
      }
    } else {
      e.reject('No alignment, styles or direction provided for Messenger iFrame');
    }
  });
  MessengerHelper.registerCommand('openWebSocket', e => {
    if (bMessengerCleared) {
      e.reject(CLEARED_REJECTION_MESSAGE);
    } else {
      function onOpened(event) {
        bindSocketEvents();
        const data = (0,util/* sanitizeObject */.Zm)(event);
        e.resolve(data);
      }
      function fOpenWebSocket() {
        const iOpenTimeout = bFireFox ? 4500 : 0; // milliseconds WEBMESS-1391
        const {
          endPoint
        } = e.data || {};
        MessengerHelper.command('GenesysVendors.WebSocket', {
          endPoint
        }).then(WebSocketAsPromised => {
          if (ws) ws.removeAllListeners(); // remove any previous instance if present, especially during reconnecting

          ws = new WebSocketAsPromised(endPoint, {
            timeout: iOpenTimeout,
            connectionTimeout: iOpenTimeout
          });
          ws.open().then(event => {
            onOpened(event);
          }).catch(error => {
            const {
              message
            } = error || {};
            if (message && message.indexOf('1006') && bFireFox) {
              // WEBMESS-1391: Try second attempt for firefox only - WebSocket closed with reason:  (1006).

              ws.open().then(evt => {
                onOpened(evt);
              }).catch(err => {
                e.reject(err);
              });
            } else {
              e.reject(error);
            }
          });
        }).catch(({
          error
        }) => {
          e.reject(error);
        });
      }
      if (e && e.commander === 'MessagingService') {
        /**
         * Check if Vendors plugin is loaded, if not load it and open socket connection
         */

        if (bVendorsPlugin) {
          fOpenWebSocket();
        } else {
          Genesys('loadPlugin', 'GenesysVendors', {}, false, () => {
            bVendorsPlugin = true;
            fOpenWebSocket();
          });
        }
      } else {
        e.reject('Unauthorized Access! Only MessagingService plugin is allowed to access this command.');
      }
    }
  });
  MessengerHelper.registerCommand('closeWebSocket', e => {
    if (e && e.commander === 'MessagingService') {
      const {
        code,
        reason
      } = e.data || {};
      if (ws && ws.close) {
        if (code) {
          ws.close(code, reason).catch(() => {});
        } else {
          ws.close().catch(() => {});
        }
      }
    } else {
      e.reject('Unauthorized Access! Only MessagingService plugin is allowed to access this command.');
    }
  });
  MessengerHelper.registerCommand('sendOverSocket', e => {
    if (bMessengerCleared) {
      e.reject(CLEARED_REJECTION_MESSAGE);
    } else if (e && e.commander === 'MessagingService') {
      ws.send(JSON.stringify(e.data || {}));
      e.resolve();
    } else {
      e.reject('Unauthorized Access! Only MessagingService plugin is allowed to access this command.');
