    Auth.command(`${sStoragePlugin}.remove`, {
      name: sAuthRefreshTknKey
    });
  }
  function removeAuthGrantType() {
    $$('authGrantType', undefined);
    Auth.command(`${sStoragePlugin}.remove`, {
      name: sAuthGrantTypeKey
    });
  }
  function clearStorage() {
    removeJwt();
    removeRefreshToken();
    removeAuthGrantType();
  }
  function onLogout(oData, e) {
    const {
      status,
      data
    } = oData || {};
    if (status) {
      switch (status) {
        case 401:
        case 403:
          // Check if implicit flow - trigger re-login instead of refresh
          const authGrantType = $$('authGrantType');
          if (authGrantType === 'implicit') {
            // Implicit flow: check if credentials are expired if guest session is expired
            const errorMessage = data && (data.message || data.error_description || '');
            const isExpiredCredentials = errorMessage.includes('The supplied credentials are expired and cannot be used');
            if (isExpiredCredentials) {
              // Credentials expired: logout from OIDC and clear local storage
              clearStorage();

              // Trigger OIDC logout via AuthProvider
              Auth.command('AuthProvider.logoutOIDC').then(() => {
                onLogoutSuccess({}, e);
                e.resolve({});
              }).catch(error => {
                // Even if OIDC logout fails, consider user logged out locally
                onLogoutError(data);
                e.reject(data);
              });
            } else {
              // Other errors: just clear local state
              onLogoutError(data);
              e.reject(data);
            }
          } else if ($$('refreshToken')) {
            // get new jwt if refreshToken is available
            Auth.command('refreshToken').then(oRefreshTokenData => {
              const {
                jwt
              } = oRefreshTokenData || {};
              if (jwt) {
                Auth.command('logout').then(oLogoutData => {
                  e.resolve(oLogoutData);
                }).catch(error => {
                  // consider it logged out
                  onLogoutError(error);
                  e.reject(error);
                });
              } else {
                // consider it logged out
                onLogoutError(oRefreshTokenData);
                e.reject(oRefreshTokenData);
              }
            }, error => {
              // consider it logged out
              onLogoutError(error);
              e.reject(error);
            }).catch(error => {
              // consider it logged out
              onLogoutError(error);
              e.reject(error);
            });
          } else {
            // consider it logged out
            onLogoutError(data);
            e.reject(data);
          }
          break;
        default:
          // consider it logged out
          onLogoutError(data);
          e.reject(data);
          break;
      }
    } else {
      // consider it logged out
      onLogoutError(data);
      e.reject(data);
    }
  }
  function onLogoutSuccess(oData, e) {
    const {
      auth
    } = oConfig || {};
    const {
      allowSessionUpgrade
    } = auth || {};
    const {
      status,
      statusText,
      data
    } = oData || {};
    const {
      keepIdentifiers
    } = e.data || {};
    bLoggingOut = false; // reset
    bPublishedSignedIn = false; // reset
    $$('authenticated', false);
    clearStorage();

    // close websocket connection and Messenger
    Auth.command('MessagingService.logout');
    if (!allowSessionUpgrade) Auth.command('Launcher.hide'); // When step-up is not enabled, maintain previous behavior.

    // To support step-up conversation, on logout purge the tokens conditionally because those needs to be retained when logout event is received in second tab onwards,
    // by this time identifiers would have been already purged from tab 1 and new ones would have been created.
    if (!keepIdentifiers) Auth.command('Identifiers.purgeAll');
    Auth.publish('loggedOut', {
      status,
      statusText,
      data
    });

    // Angelo suggests to follow signIn naming convention. So, to sync up without breaking existing event, adding this new event.
    Auth.publish('signedOut', {
      status,
      statusText,
      data
    });
  }
  function onLogoutError(oData) {
    const {
      status,
      statusText,
      data
    } = oData || {};
    bLoggingOut = false; // reset
    bPublishedSignedIn = false; // reset
    $$('authenticated', false);
    clearStorage();

    // close websocket connection and Messenger
    Auth.command('MessagingService.logout');
    Auth.command('Launcher.hide');
    Auth.publish('logoutError', {
      status,
      statusText,
      data
    });
  }
  function initAndFetchToken(data) {
    const {
      authCode
    } = data || {};
    const oSignedInData = {};
    const pOnSignedIn = new Promise((resolve, reject) => {
      if (authCode) {
        if (!bFetchingToken) {
          bFetchingToken = true;
          oSignedInData.authCode = authCode;
          Auth.republish('signedIn', oSignedInData);
          bPublishedSignedIn = true;
          // execute getToken using this authCode
          Auth.command('GenesysJS.init').then(oToken => {
            const {
              jwt
            } = oToken || {};
            bFetchingToken = false; // reset

            if (jwt) {
              oSignedInData.jwt = oToken.jwt || '';
              removeSigningIn();
              resolve(oSignedInData);
            } else {
              removeSigningIn();
              reject('Unable to fetch authentication token');
            }
          }, () => {
            // error
            bFetchingToken = false; // reset
          });
        }
      } else {
        removeSigningIn();
        reject('Auth code unavailable, signIn failed');
      }
    });
    return pOnSignedIn;
  }
  function checkConfigAndinit(config, data) {
    const {
      auth
    } = config || {};
    const {
      allowSessionUpgrade
    } = auth || {};
    const {
      authCode
    } = data || {};
    const bAuthenticated = $$('authenticated');
    if (!bAuthenticated && (allowSessionUpgrade || authCode)) {
      initAndFetchToken(data);
    } else if (!bPublishedSignedIn && bAuthenticated && authCode) {
      Auth.republish('signedIn', data);
    }
  }

  /**
   * function that returns promise resolving with boolean indicating if AuthProvider.signIn command is defined by the brand.
   * @return promise
   */
  async function awaitSignInProvider() {
    const bSignInAvailable = await Genesys('lookup', 'AuthProvider.signIn');
    return bSignInAvailable;
  }

  /**
   * store the tokens in the data model when it is available in the local storage
   */
  function checkTokensAndStore() {
    Auth.command(`${sStoragePlugin}.get`, {
      names: [sAuthTokenKey, sAuthRefreshTknKey, sAuthGrantTypeKey]
    }).then(oTokens => {
      // These are not random inputs from user. For any security related scanning, this can be safely ignored.
      if (oTokens[sAuthTokenKey] && oTokens[sAuthTokenKey] !== 'undefined') {
        // eslint-disable-line
        $$('jwt', oTokens[sAuthTokenKey]); // eslint-disable-line
        $$('authenticated', true);
      }

      // These are not random inputs from user. For any security related scaning, this can be safely ignored.
      if (oTokens[sAuthRefreshTknKey] && oTokens[sAuthRefreshTknKey] !== 'undefined') {
        // eslint-disable-line
        $$('refreshToken', oTokens[sAuthRefreshTknKey]); // eslint-disable-line
      }

      // Restore authGrantType from localStorage
      if (oTokens[sAuthGrantTypeKey] && oTokens[sAuthGrantTypeKey] !== 'undefined') {
        // eslint-disable-line
        $$('authGrantType', oTokens[sAuthGrantTypeKey]); // eslint-disable-line
      }

      // Republish authenticated event for step-up conversation
      // For authorization code flow: requires both JWT and refresh token
      // For implicit flow: requires only JWT (ID token)
      const jwt = $$('jwt');
      const refreshToken = $$('refreshToken');
      const authGrantType = $$('authGrantType');
      if (jwt) {
        const authData = {
          jwt,
          authGrantType
        };

        // Only include refreshToken for authorization code flow
        if (authGrantType !== 'implicit' && refreshToken) {
          authData.refreshToken = refreshToken;
        }
        Auth.republish('authenticated', authData);
      }
    });
  }
  function retryWithBackoff(commandName, e, attempt) {
    attempt = attempt || 0;
    if (bCleared || attempt >= MAX_RETRY_ATTEMPTS) {
      const retryErrorData = {
        error: bCleared ? 'cleared' : 'retry_exhausted',
        error_description: bCleared ? `${commandName} retry aborted: Messenger is cleared` : `${commandName} failed after ${MAX_RETRY_ATTEMPTS} retry attempts due to 504 timeout`,
        authGrantType: $('authGrantType')
      };
      Auth.publish('error', retryErrorData);
      e.reject(retryErrorData);
      return;
    }
    setTimeout(() => {
      if (bCleared) {
        e.reject(CLEARED_REJECTION_MESSAGE);
        return;
      }
      Auth.command(commandName, {
        _retryAttempt: attempt + 1
      }).then(oData => e.resolve(oData), error => e.reject(error));
    }, INITIAL_RETRY_DELAY_MS * Math.pow(2, attempt));
  }
  function retryAxiosOnce(error, e, onSuccess) {
    const RETRYABLE_API_PATHS = [`${sApiEndpoint}/api/v2/webdeployments/token/oauthcodegrantjwtexchange`, `${sApiEndpoint}/api/v2/webdeployments/token/refresh`];
    if (e._authRetried) {
      e.reject('Unable to fetch authentication token');
      return;
    }
    e._authRetried = true;
    const {
      method,
      url,
      data,
      headers,
      responseType
    } = error.config || {};
    setTimeout(() => {
      if (RETRYABLE_API_PATHS.includes(url)) {
        lib_axios({
          method,
          url,
          data,
          headers,
          responseType
        }).then(onSuccess, () => {
          e.reject('Unable to fetch authentication token');
        });
      } else {
        e.reject('Unable to fetch authentication token');
      }
    }, INITIAL_RETRY_DELAY_MS);
  }
  Auth.command('Identifiers.getJourneyContext').then(data => {
    const {
      customer,
      customerSession
    } = data;
    if (customer && Object.keys(customer).length && customerSession && Object.keys(customerSession).length) {
      const oTemp = $$('journeyContext');
      $$('journeyContext', (0,util/* merge */.h1)(true, oTemp, data));
    }
  });

  // After cross-domain support, need to subscribe to LocalStorage ready event and then fetch storage data.
  Auth.subscribe('LocalStorage.ready', () => {
    checkTokensAndStore();
  });

  /* Register Commands */

  Auth.registerCommand('signIn', e => {
    if (!bCleared) {
      const {
        auth
      } = oConfig || {};
      const {
        allowSessionUpgrade
      } = auth || {};
      if (!isSignInAvailable) e.reject('AuthProvider.signIn command must be defined');
      if (!$$('signingIn')) {
        // while signingIn is not in progress
        if (allowSessionUpgrade) {
          setSigningIn();
          Auth.command('AuthProvider.signIn').then(data => {
            initAndFetchToken(data).then(successData => {
              e.resolve(successData);
            }, error => {
              e.reject(error);
            });
          }, failed => {
            e.reject(failed); // when AuthProvider.signIn command is rejected
          });
        } else {
          e.reject('upgrade to authenticated session must be enabled.');
        }
      }
    } else e.reject(CLEARED_REJECTION_MESSAGE);
  });

  /**
   * Fetch jwt from the auth code provided by the brand
   * Accepted params
   *  - authCode
   * returns
   *  - jwt
   */
  Auth.registerCommand('getTokens', e => {
    if (!bCleared) {
      const {
        deploymentConfig,
        snippetConfig
      } = e.data || {};
      const {
        apiEndpoint
      } = deploymentConfig || {};
      const {
        deploymentId
      } = snippetConfig || {};
      if (apiEndpoint) sApiEndpoint = apiEndpoint;
      if (deploymentId) sDeploymentId = deploymentId;
      if (typeof deploymentConfig === 'object') oConfig = deploymentConfig;

      // eslint-disable-next-line complexity
      Auth.command('AuthProvider.getAuthCode', e.data).then(data => {
        const {
          authCode,
          redirectUri,
          nonce,
          maxAge,
          codeVerifier,
          iss,
          idToken
        } = data || {};
        removeSigningIn(deploymentConfig); // authCode is available, removing signingIn storage

        // Validate that both authCode and idToken are not provided simultaneously
        if (authCode && idToken) {
          const errorData = {
            error: 'invalid_grant',
            error_description: 'Brand provided both authCode and idToken. Only one grant type is allowed.',
            authCode,
            idToken
          };
          $('authenticated', false);
          Auth.publish('authError', errorData);
          e.reject(errorData);
          return;
        }
        if ((authCode || idToken) && redirectUri) {
          let sOauth;
          if (authCode) {
            sOauth = {
              code: authCode,
              redirectUri
            };
          } else {
            sOauth = {
              idToken: idToken,
              redirectUri
            };
          }
          if (codeVerifier) sOauth.codeVerifier = codeVerifier;
          if (nonce) sOauth.nonce = nonce;
          if (maxAge) sOauth.maxAge = maxAge;
          if (iss) sOauth.iss = iss;
          $$('authId', authCode || idToken); // set 'authId' in the data model (use idToken for implicit flow)

          // Set and publish authGrantType based on response
          const authGrantType = authCode ? 'authorizationCode' : 'implicit';
          setAuthGrantType(authGrantType);
          Auth.publish('authGrantType', {
            authGrantType
          });
          if (authCode) {
            Auth.publish('authenticating', {
              authCode,
              redirectUri
            });
          } else {
            Auth.publish('authenticating', {
              idToken,
              redirectUri
            });
          }
          if (sApiEndpoint && sDeploymentId) {
            lib_axios({
              url: `${sApiEndpoint}/api/v2/webdeployments/token/oauthcodegrantjwtexchange`,
              method: 'post',
              responseType: 'json',
              data: {
                deploymentId: sDeploymentId,
                oauth: sOauth,
                journeyContext: $$('journeyContext') || {}
              }
            }).then(response => {
              const {
                jwt,
                refreshToken
              } = response && response.data || {};
              if (jwt) {
                $$('authenticated', true); // set 'authenticated' state in the data model

                setJwt(jwt);
                setRefreshToken(refreshToken);
                Auth.republish('authenticated', {
                  // publish "authenticated" event
                  jwt,
                  refreshToken,
                  authGrantType
                });
                e.resolve({
                  jwt,
                  refreshToken
                });
              } else {
                $$('authenticated', false);
                Auth.publish('tokenError', JSON.parse({
                  response
                })); // publish "tokenError" event when no jwt is provided

                e.reject('Invalid or no token received');
              }
            }, error => {
              const {
                data: oErrorData
              } = error.response || {};
              $$('authenticated', false);
              Auth.publish('error', oErrorData || {}); // publish "error" event when the request fails

              const {
                status
              } = error && error.response || {};
              if (status) {
                switch (status) {
                  case 401: // unauthorized, retry once
                  case 403:
                    // forbidden, retry once
                    retryAxiosOnce(error, e, response => {
