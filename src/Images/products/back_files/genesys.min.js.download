                break;
            }
          } else {
            e.reject('Unable to fetch authentication token');
          }
        });
      } else {
        clearStorage();
        Auth.command('getTokens', {
          forceUpdate: true
        }).then(data => {
          e.resolve(data);
        }).catch(() => {
          $$('authenticated', false);
          e.reject('Unable to get tokens');
        });
      }
    } else e.reject(CLEARED_REJECTION_MESSAGE);
  });
  Auth.registerCommand('configure', e => {
    const {
      deploymentConfig,
      snippetConfig
    } = e.data || {};
    const {
      apiEndpoint
    } = deploymentConfig || {};
    const {
      deploymentId
    } = snippetConfig || {};
    if (!bCleared) {
      if (typeof deploymentConfig === 'object') oConfig = deploymentConfig;
      if (apiEndpoint && deploymentId) {
        sApiEndpoint = apiEndpoint;
        sDeploymentId = deploymentId;
        Auth.republish('configured');
        e.resolve();
      } else {
        e.reject();
      }
    } else e.reject(CLEARED_REJECTION_MESSAGE);
  });
  Auth.registerCommand('reAuthenticate', e => {
    if (!bCleared) {
      clearStorage();
      Auth.command('AuthProvider.reAuthenticate').then(() => {
        Auth.command('getTokens').then(data => {
          e.resolve(data);
        });
      }).catch(error => {
        e.reject(error || 'Unable to reauthenticate');
      });
    } else e.reject(CLEARED_REJECTION_MESSAGE);
  });

  //command to be called by master clear command to set boolean true and reject all other commands
  Auth.registerCommand('clear', e => {
    if (e && e.commander && e.commander !== 'Messenger') {
      e.reject(`${e.commander} plugin does not have permission to access clear Auth plugin command`);
    }
    bCleared = true;
    Auth.publish('cleared');
    e.resolve();
  });

  /**
   * WEBMESS-1116
   * Optional: Command called by MessagingService plugin to read configureOnly setting from customer's AuthProvider plugin.
   */
  Auth.registerCommand('getSettings', e => {
    if (!bCleared) {
      const settings = Auth.data('AuthProvider.settings');
      e.resolve(settings);
    } else e.reject(CLEARED_REJECTION_MESSAGE);
  });

  // subscribe to MessagingService plugin event to know that conversation is steppedUp. This event is published in all tabs.
  // This is for handling when configureAuthenticatedSession request succeeds in 2nd tab without user signed there (stepped-up)

  Auth.subscribe('MessagingService.steppedUpConversation', () => {
    checkTokensAndStore();
  });

  // Duplicate tabs will subscribe to this event and publishes authenticated event in that tab so UI updates its state.
  Auth.subscribe('MessagingService.authenticated', () => {
    const bAuthenticated = $$('authenticated');
    if (!bAuthenticated) checkTokensAndStore();
  });

  // provide a standalone event to indicate the authorization state has changed
  // To do this, we are subscribing to our own data model and publishing a named
  // event when the value changes. CXBus automatically publishes discrete data
  // events when there is 1 or more subscribers to a given datapoint.
  Auth.subscribe('data.authenticated', () => {
    Auth.publish('changed', {
      authenticated: $$('authenticated'),
      jwt: $$('jwt'),
      refreshToken: $$('refreshToken'),
      authGrantType: $$('authGrantType')
    });
  });

  // Subscribe to GPE journey event and merge the journeyContext to send along the oauth exchange request
  //block this with clear command
  Auth.subscribe('Journey.qualifiedWebMessagingOffer', e => {
    const {
      journeyContext
    } = e.data;
    const oCurrentData = $$('journeyContext');
