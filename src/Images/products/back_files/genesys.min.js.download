    } else {
      if (ndMessengerWrapper) {
        if (ndIframe) {
          if (ndIframe.hasAttribute('hidden')) ndIframe.removeAttribute('hidden');
        }
        if (ndMessengerWrapper.hasAttribute('aria-modal')) ndMessengerWrapper.removeAttribute('aria-modal');
        if (ndMessengerWrapper.hasAttribute('role') && !(0,util/* isIphone */.sf)())
          // removal of role dialog dynamically on iphone causes voiceover focus loss.
          ndMessengerWrapper.removeAttribute('role');
      }
    }
  }

  /**
   * function returns dimensions for a given element
   */
  function getDimension(ndContainer) {
    return {
      bottom: window.getComputedStyle(ndContainer).getPropertyValue('bottom') || '',
      top: window.getComputedStyle(ndContainer).getPropertyValue('top') || '',
      height: window.getComputedStyle(ndContainer).getPropertyValue('height') || '',
      width: window.getComputedStyle(ndContainer).getPropertyValue('width') || ''
    };
  }

  /**
   * function returns empty string if given string contains the text "javascript"
   */
  function checkForJavascript(string) {
    if (string && !!string.toLowerCase().match(/javascript/)) return '';else return string;
  }

  //Subscribe to master cleared event and reject all other commands after
  MessengerHelper.subscribe('Messenger.cleared', () => {
    const ndLauncherIframe = document.getElementById('genesys-mxg-frame');
    const ndMessengerFrame = document.getElementById('genesys-mxg-container-frame');
    if (ndLauncherIframe) setIframeDimension(ndLauncherIframe, 0, 0);
    if (ndMessengerFrame) setIframeDimension(ndMessengerFrame, 0, 0);
    bMessengerCleared = true;
    MessengerHelper.publish('cleared');
  });
  MessengerHelper.subscribe('ServiceDiscovery.ready', () => {
    // [WEBMESS-16] Get the version from browser global if present. Remove this before releasing
    const sVersion = window._webMessVersion ? `/${window._webMessVersion}` : '';
    const sMessengerHTML = `${MessengerHelper.data('ServiceDiscovery.uris.staticAssets')}/messenger${sVersion}/messenger.html`;
    const sMessengerRendererHTML = `${MessengerHelper.data('ServiceDiscovery.uris.staticAssets')}/messenger${sVersion}/messenger-renderer.html`;
    customLabelUrl = `${MessengerHelper.data('ServiceDiscovery.uris.configs')}`;
    /** False positive - disable eslint HTML passed into function rule. We don't inject external html here. */
    iframeHtml = iframeHtml.replace('{url}', sMessengerHTML); // eslint-disable-line
    iframeHtml = iframeHtml.replace('{messenger-renderer-url}', sMessengerRendererHTML); // eslint-disable-line
  });
  MessengerHelper.registerCommand('open', e => {
    // eslint-disable-line
    if (bMessengerCleared) {
      e.reject(CLEARED_REJECTION_MESSAGE);
    } else if ($$('iFrameLoaded')) {
      e.reject('Messenger iframe is already open');
    } else {
      const {
        messenger
      } = e.data || {};
      const {
        preview
      } = messenger || {};
      const deploymentConfig = MessengerHelper.data('GenesysJS.deploymentConfig') || {};
      const snippetConfig = MessengerHelper.data('GenesysJS.snippetConfig') || {};
      const {
        position,
        messenger: oMessengerConfig
      } = deploymentConfig || {};
      const {
        launcherButton
      } = oMessengerConfig || {};
      const {
        visibility
      } = launcherButton || {};

      //set the messenger config position
      if (position) {
        setPositionValues(position);
      }
      if (visibility && visibility.toLowerCase() === 'on') {
        iframeHtml = iframeHtml.replace('messengerFrameBottomSpace', "92px"); // eslint-disable-line
      } else {
        iframeHtml = iframeHtml.replace('messengerFrameBottomSpace', `${oPosition.bottomSpace}px`); // eslint-disable-line
      }

      //apply the nearest vertical border and bottom pixels from config
      iframeHtml = iframeHtml.replace('sideSpace', `${oPosition.sideSpace}px`); // eslint-disable-line
      iframeHtml = iframeHtml.replace('bottomSpace', `${oPosition.bottomSpace}px`); // eslint-disable-line

      // inject iframe into the parent page
      document.body.appendChild((0,util/* stringToHTML */._0)(iframeHtml));

      // configure Messenger when it is not running in preview mode
      if (!preview) {
        MessengerHelper.subscribe('Messenger.ready', () => {
          MessengerHelper.command('Messenger.configure', {
            snippetConfig,
            deploymentConfig,
            // TODO: remove once the plugin has been updated to use deploymentConfig/snippetConfig
            deploymentId: snippetConfig.deploymentId,
            config: {
              ...deploymentConfig.messenger,
              documentDirection: sDocumentDirection
            }
          });
        });
      }
      $$('iFrameLoaded', true);
      e.resolve();
    }
  });
  MessengerHelper.registerCommand('update', e => {
    if (bMessengerCleared) {
      e.reject(CLEARED_REJECTION_MESSAGE);
    } else {
      const {
        messenger
      } = e.data || {};
      const {
        preview
      } = messenger || {};
      const deploymentConfig = MessengerHelper.data('GenesysJS.deploymentConfig') || {};
      const snippetConfig = MessengerHelper.data('GenesysJS.snippetConfig') || {};

      // configure Messenger when it is not running in preview mode
      if (!preview) {
        MessengerHelper.command('Messenger.configure', {
          snippetConfig,
          deploymentConfig,
          // TODO: remove once the plugin has been updated to use deploymentConfig/snippetConfig
          deploymentId: snippetConfig.deploymentId,
          config: {
            ...deploymentConfig.messenger,
            documentDirection: sDocumentDirection
          }
        });
      }
      e.resolve();
    }
  });

  /** Internal only - Do not document */
  /**
