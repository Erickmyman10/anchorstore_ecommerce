                }
              } else {
                e.reject('Unable to fetch authentication token');
              }
            });
          } else {
            e.reject('No configuration available');
          }
        } else {
          Auth.publish('authError', data); // publish "authError" event when no code is provided

          e.resolve(); // resolve empty
        }
      }, error => {
        const {
          data: oErrorData
        } = error.response || {};
        Auth.publish('authProviderError', oErrorData || {}); // publish "authProviderError" event when the brand "AuthProvider" plugin fails to resolve

        e.reject('Unable to get Authorization code');
      });
    } else e.reject(CLEARED_REJECTION_MESSAGE);
  });

  /**
   * data {
   *  keepIdentifiers
   *  forceClearCache
   * }
   */
  Auth.registerCommand('logout', e => {
    if (!bCleared) {
      const {
        forceClearCache
      } = e.data || {};
      const deploymentConfig = $$('GenesysJS.deploymentConfig') || {};
      const {
        messenger
      } = deploymentConfig || {};
      const {
        enabled: bMessengerEnabled
      } = messenger || {};
      let sMessengerOpenStorage = '_gcmcopn';
      bLoggingOut = true;
      removeSigningIn();
      if ($$('authenticated')) {
        if (sDeploymentId) sMessengerOpenStorage = `${sDeploymentId}:gcmcopn`;
        if (bMessengerEnabled) {
          // Get cookie related to messenger only when Messenger is enabled
          Auth.command(`${sStoragePlugin}.get`, {
            name: sMessengerOpenStorage
          }).then(data => {
            if (data) {
              const [gcmcopn] = data.split(':');
              if (gcmcopn && typeof gcmcopn === 'string') {
                if (gcmcopn === 'true') {
                  // if UI state is opened,
                  Auth.command('Messenger.close'); // close Messenger
                }
              }
            }
          });
        }

        /**
        * Remove tokens from storage immediately when forceClearCache is set.
        * This can help in cases where brand doesn't want to wait for the /logout to succeed before clearing the storage data.
        **/

        if (forceClearCache) {
          $$('authenticated', false);
          clearStorage();
        }
        Auth.command('Identifiers.getSessionId').then(sessionId => lib_axios({
          url: `${sApiEndpoint}/api/v2/webdeployments/token/revoke`,
          method: 'delete',
          headers: {
            'Authorization': `Bearer ${$$('jwt')}`,
            'X-Journey-Session-Id': sessionId,
            'X-Journey-Session-Type': 'web'
          }
        }).then(response => {
          const {
            status
          } = response || {};
          if (status === 204) {
            // 204 response code is sent back from Public API in order to resolve 'XML Parsing Error' in Firefox browser.
            onLogoutSuccess(response, e);
            e.resolve(JSON.parse(JSON.stringify({
              status: response.status || '',
              statusText: response.statusText || '',
              data: response.data || ''
            })));
          } else {
            onLogout(response, e);
          }
        }, error => {
          onLogout(error.response, e);
        })).catch(error => {
